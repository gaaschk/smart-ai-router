#!/usr/bin/env bash
# claudish-smart — point claudish at smart-ai-router's OpenAI-compatible proxy.
#
# Every request from Claude Code flows through POST /v1/chat/completions, which
# classifies the prompt and routes it to the best available model per call.
#
# Usage:
#   claudish-smart [claudish args...]
#
# Overrides:
#   SMART_ROUTER_URL=http://my-host:8001   change router address
#   SMART_ROUTER_OPTIONAL=1               fall back to claudish defaults if unreachable

set -euo pipefail

ROUTER="${SMART_ROUTER_URL:-http://kevins-mac-mini.local:8001}"
OPTIONAL="${SMART_ROUTER_OPTIONAL:-0}"

die() { echo "[claudish-smart] ERROR: $*" >&2; exit 1; }

# Check router reachability
if ! curl -sf --max-time 3 "$ROUTER/api/updates?fetch=false" > /dev/null 2>&1; then
  if [ "$OPTIONAL" = "1" ]; then
    echo "[claudish-smart] smart-ai-router unreachable at $ROUTER — using claudish defaults" >&2
    exec claudish "$@"
  else
    die "smart-ai-router unreachable at $ROUTER. Check the service is running, or set SMART_ROUTER_OPTIONAL=1 to fall back."
  fi
fi

echo "[claudish-smart] routing via $ROUTER/v1 (per-request classification)" >&2

# Point claudish's LiteLLM provider at the proxy.
# claudish sends OpenAI-format requests to LITELLM_BASE_URL/chat/completions.
# The proxy classifies each prompt and forwards to the best model.
export LITELLM_BASE_URL="$ROUTER"
export LITELLM_API_KEY="smart-ai-router"   # arbitrary non-empty value

# Override Bedrock config via project-level settings.local.json (higher priority
# than ~/.claude/settings.json). Drop exec so the EXIT trap fires for cleanup.
_LOCAL_SETTINGS="$PWD/.claude/settings.local.json"
_LOCAL_SETTINGS_BACKUP=""

mkdir -p "$PWD/.claude"

if [ -f "$_LOCAL_SETTINGS" ]; then
  _LOCAL_SETTINGS_BACKUP=$(mktemp)
  cp "$_LOCAL_SETTINGS" "$_LOCAL_SETTINGS_BACKUP"
fi

cat > "$_LOCAL_SETTINGS" <<'SETTINGS'
{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "ANTHROPIC_MODEL": "",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": ""
  }
}
SETTINGS

cleanup() {
  if [ -n "$_LOCAL_SETTINGS_BACKUP" ]; then
    mv "$_LOCAL_SETTINGS_BACKUP" "$_LOCAL_SETTINGS"
  else
    rm -f "$_LOCAL_SETTINGS"
    rmdir "$PWD/.claude" 2>/dev/null || true
  fi
}
trap cleanup EXIT

# Orchestration roles (opus/sonnet/haiku) drive the main Claude Code loop —
# recognizing skills, emitting Workflow/Agent tool calls. These need a
# Claude-compliant model, so they use the 'smart-orchestrator' name which the
# proxy forces to a Claude model (via bedrock).
#
# The subagent role does the actual fan-out work; it uses 'smart-worker' which
# the proxy classifies and routes to the cheapest capable model (Claude fallback
# when nothing third-party clears the quality bar).
claudish \
  --model-opus     "ll@smart-orchestrator" \
  --model-sonnet   "ll@smart-orchestrator" \
  --model-haiku    "ll@smart-orchestrator" \
  --model-subagent "ll@smart-worker" \
  "$@"
