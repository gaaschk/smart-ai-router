#!/usr/bin/env bash
# claudish-smart — wrap claudish with model roles resolved from smart-ai-router.
#
# Usage:
#   claudish-smart [claudish args...]
#
# smart-ai-router maps:
#   opus    -> reasoning / hard
#   sonnet  -> coding / moderate  (default role)
#   haiku   -> general / trivial
#
# By default the router is REQUIRED — the script aborts if it is unreachable or
# returns no models. To allow falling back to claudish defaults instead, set:
#   SMART_ROUTER_OPTIONAL=1  claudish-smart
#
# The router URL can be overridden:
#   SMART_ROUTER_URL=http://my-host:8001  claudish-smart

set -euo pipefail

ROUTER="${SMART_ROUTER_URL:-http://kevins-mac-mini.local:8001}"
OPTIONAL="${SMART_ROUTER_OPTIONAL:-0}"

die() { echo "[claudish-smart] ERROR: $*" >&2; exit 1; }

route() {
  local domain="$1" complexity="$2"
  curl -sf -X POST "$ROUTER/api/route" \
    -H "Content-Type: application/json" \
    -d "{\"domain\":\"$domain\",\"complexity\":\"$complexity\"}" \
    | python3 -c "
import sys, json
m = json.load(sys.stdin)['model']
# convert 'provider/rest' -> 'provider@rest' (claudish modern syntax)
parts = m.split('/', 1)
print(parts[0] + '@' + parts[1] if len(parts) == 2 else m)
" 2>/dev/null
}

OPUS_MODEL=""
SONNET_MODEL=""
HAIKU_MODEL=""

if curl -sf --max-time 3 "$ROUTER/api/updates?fetch=false" > /dev/null 2>&1; then
  OPUS_MODEL=$(route "reasoning" "hard" || true)
  SONNET_MODEL=$(route "coding" "moderate" || true)
  HAIKU_MODEL=$(route "general" "trivial" || true)

  if [ -z "$SONNET_MODEL" ]; then
    if [ "$OPTIONAL" = "1" ]; then
      echo "[claudish-smart] router returned no models — falling back to claudish defaults" >&2
    else
      die "smart-ai-router at $ROUTER returned no models. Run a sync first, or set SMART_ROUTER_OPTIONAL=1 to fall back to claudish defaults."
    fi
  fi
else
  if [ "$OPTIONAL" = "1" ]; then
    echo "[claudish-smart] smart-ai-router unreachable at $ROUTER — falling back to claudish defaults" >&2
  else
    die "smart-ai-router unreachable at $ROUTER. Check the service is running, or set SMART_ROUTER_OPTIONAL=1 to fall back to claudish defaults."
  fi
fi

EXTRA_ARGS=()
[ -n "$OPUS_MODEL" ]   && EXTRA_ARGS+=(--model-opus     "$OPUS_MODEL")
[ -n "$SONNET_MODEL" ] && EXTRA_ARGS+=(--model-sonnet   "$SONNET_MODEL")
[ -n "$HAIKU_MODEL" ]  && EXTRA_ARGS+=(--model-haiku    "$HAIKU_MODEL")
[ -n "$SONNET_MODEL" ] && EXTRA_ARGS+=(--model-subagent "$SONNET_MODEL")

if [ ${#EXTRA_ARGS[@]} -gt 0 ]; then
  echo "[claudish-smart] routing: opus=$OPUS_MODEL sonnet=$SONNET_MODEL haiku=$HAIKU_MODEL" >&2
fi

# Inject API keys from stored provider configs so claudish doesn't prompt.
# Only sets a variable if it isn't already in the environment.
_providers=$(curl -sf --max-time 3 "$ROUTER/api/providers" 2>/dev/null || true)
if [ -n "$_providers" ]; then
  _or_key=$(echo "$_providers" | python3 -c "
import sys, json
for p in json.load(sys.stdin):
    if p.get('kind') == 'openrouter' and p.get('api_key'):
        print(p['api_key']); break
" 2>/dev/null || true)
  [ -n "$_or_key" ] && [ -z "${OPENROUTER_API_KEY:-}" ] && export OPENROUTER_API_KEY="$_or_key"
fi

# ~/.claude/settings.json has CLAUDE_CODE_USE_BEDROCK=1 and Bedrock ARNs in its
# env block. Claude Code loads settings.local.json last at highest priority.
# Write a temporary settings.local.json that zeros out the Bedrock config,
# then remove it when the session exits.
_SETTINGS_LOCAL="$HOME/.claude/settings.local.json"
_SETTINGS_LOCAL_BACKUP=""

if [ -f "$_SETTINGS_LOCAL" ]; then
  _SETTINGS_LOCAL_BACKUP=$(mktemp)
  cp "$_SETTINGS_LOCAL" "$_SETTINGS_LOCAL_BACKUP"
fi

cat > "$_SETTINGS_LOCAL" <<'SETTINGS'
{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "ANTHROPIC_MODEL": "",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": ""
  }
}
SETTINGS

cleanup() {
  if [ -n "$_SETTINGS_LOCAL_BACKUP" ]; then
    mv "$_SETTINGS_LOCAL_BACKUP" "$_SETTINGS_LOCAL"
  else
    rm -f "$_SETTINGS_LOCAL"
  fi
}
trap cleanup EXIT

exec claudish "${EXTRA_ARGS[@]}" "$@"
